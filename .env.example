# Backend
APP_NAME=Invoice AI

APP_ENV=development

DEBUG=True

HOST=0.0.0.0

PORT=8000

BACKEND_PUBLIC_URL=http://localhost:8000

# Database
POSTGRES_DB=invoice_ai

POSTGRES_USER=postgres

POSTGRES_PASSWORD=postgres

POSTGRES_HOST=postgres

POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/invoice_ai

# Redis
REDIS_HOST=redis

REDIS_PORT=6379

# File Upload
MAX_UPLOAD_SIZE_MB=20

UPLOAD_DIR=uploads

TEMP_DIR=temp

PDF_RENDER_DPI=300

PDF_IMAGE_FORMAT=png

# AI
MODEL_DIR=models/layoutlmv3

DEVICE=cuda